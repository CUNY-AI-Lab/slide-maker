{
  "id": "artifact-leaflet-markers",
  "name": "Leaflet Map",
  "description": "An interactive Leaflet map with markers, multiple tile styles (default, dark, light, satellite), zoom and pan. Configure markers, center, zoom, and tile style.",
  "type": "map",
  "source": "<!DOCTYPE html><html><head><link rel=\"stylesheet\" href=\"/api/static/leaflet.css\"/><script src=\"/api/static/leaflet.js\"><\/script><style>body{margin:0;height:100vh;overflow:hidden}#map{width:100%;height:100%}.info{padding:6px 10px;background:rgba(30,41,59,0.9);color:#e2e8f0;border-radius:6px;font:13px Inter,system-ui,sans-serif;box-shadow:0 2px 8px rgba(0,0,0,.3)}.info b{display:block;font-size:14px;margin-bottom:2px}.leaflet-control-attribution{font-size:10px!important}</style></head><body data-config=\"{}\"><div id=\"map\"></div><script>var cfg=JSON.parse(document.body.getAttribute('data-config')||'{}');var markers=cfg.markers||[{lat:40.7128,lng:-74.006,label:'New York',value:'Pop: 8.3M'},{lat:34.0522,lng:-118.2437,label:'Los Angeles',value:'Pop: 3.9M'},{lat:41.8781,lng:-87.6298,label:'Chicago',value:'Pop: 2.7M'},{lat:29.7604,lng:-95.3698,label:'Houston',value:'Pop: 2.3M'},{lat:33.749,lng:-84.388,label:'Atlanta',value:'Pop: 498K'}];var center=cfg.center||[39.8,-98.6];var zoom=cfg.zoom||4;var style=cfg.style||'default';var tiles={default:'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',dark:'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',light:'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',satellite:'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}'};var map=L.map('map',{zoomControl:true}).setView(center,zoom);L.tileLayer(tiles[style]||tiles.default,{maxZoom:18,attribution:'\\u00a9 OpenStreetMap'}).addTo(map);markers.forEach(function(m){var mk=L.circleMarker([m.lat,m.lng],{radius:8,fillColor:'#3b82f6',color:'#1e3a8a',weight:2,fillOpacity:0.85});var popupEl=document.createElement('div');popupEl.className='info';var b=document.createElement('b');b.textContent=m.label;popupEl.appendChild(b);if(m.value){var sp=document.createElement('span');sp.textContent=m.value;popupEl.appendChild(sp)}mk.bindPopup(popupEl);mk.addTo(map)})<\/script></body></html>",
  "config": {
    "markers": {
      "type": "array",
      "label": "Map Markers",
      "itemShape": { "lat": "number", "lng": "number", "label": "string", "value": "string" },
      "default": [
        { "lat": 40.7128, "lng": -74.006, "label": "New York", "value": "Pop: 8.3M" },
        { "lat": 34.0522, "lng": -118.2437, "label": "Los Angeles", "value": "Pop: 3.9M" },
        { "lat": 41.8781, "lng": -87.6298, "label": "Chicago", "value": "Pop: 2.7M" }
      ]
    },
    "center": {
      "type": "array",
      "label": "Map Center [lat, lng]",
      "default": [39.8, -98.6]
    },
    "zoom": {
      "type": "number",
      "label": "Zoom Level (1-18)",
      "default": 4
    },
    "style": {
      "type": "string",
      "label": "Map Style",
      "default": "dark",
      "enum": ["default", "dark", "light", "satellite"]
    }
  }
}
