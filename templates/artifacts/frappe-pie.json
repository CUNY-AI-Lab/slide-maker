{
  "id": "artifact-frappe-pie",
  "name": "Pie Chart",
  "description": "Colorful pie chart with interactive hover effects, legend, and percentage display.",
  "type": "chart",
  "source": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>*{margin:0;padding:0;box-sizing:border-box}body{background:transparent;overflow:hidden;font-family:Inter,system-ui,sans-serif}#chart{width:100%;min-height:200px}.frappe-chart .axis text,.frappe-chart .chart-label{fill:#94a3b8!important}</style></head><body data-config=\"{}\"><div id=\"chart\"></div><script src=\"/api/static/frappe-charts.min.umd.js\"><\/script><script>function initChart(){try{var cfg=JSON.parse(document.body.getAttribute('data-config')||'{}');var el=document.getElementById('chart');var d=cfg.data||{labels:['Research','Teaching','Admin','Service','Outreach'],datasets:[{values:[35,25,20,12,8]}]};var c=cfg.colors||['#3b82f6','#6366f1','#f59e0b','#10b981','#ef4444'];var h=Math.max(200,document.documentElement.clientHeight-20);var chart=new frappe.Chart(el,{data:d,type:'pie',height:h,colors:c,animate:1,truncateLegends:1});var tid=0;new ResizeObserver(function(){clearTimeout(tid);tid=setTimeout(function(){var nh=Math.max(200,document.documentElement.clientHeight-20);chart=new frappe.Chart(el,{data:d,type:'pie',height:nh,colors:c,animate:0,truncateLegends:1})},150)}).observe(document.body)}catch(e){var p=document.createElement('p');p.style.cssText='color:#f87171;padding:20px';p.textContent='Chart error: '+e.message;document.body.appendChild(p)}}function waitForLayout(){var el=document.getElementById('chart');if(el&&el.offsetWidth>0){initChart()}else{requestAnimationFrame(waitForLayout)}}requestAnimationFrame(waitForLayout)<\/script></body></html>",
  "config": {
    "data": {
      "type": "object",
      "label": "Chart Data",
      "default": {
        "labels": ["Research", "Teaching", "Admin", "Service", "Outreach"],
        "datasets": [{ "values": [35, 25, 20, 12, 8] }]
      }
    },
    "colors": {
      "type": "array",
      "label": "Slice Colors",
      "default": ["#3b82f6", "#6366f1", "#f59e0b", "#10b981", "#ef4444"]
    }
  }
}
